{
  "expo": {
    "name": "guvi",
    "slug": "guvi",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.jpg",
    "scheme": "guvi",
    "userInterfaceStyle": "automatic",
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.jpg",
        "backgroundColor": "#F5F0E1"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF"
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/ProductSansRegular.ttf",
            "./assets/fonts/ProductSansBold.ttf"
          ]
        }
      ],
      "expo-image",
      "expo-status-bar",
      "expo-web-browser",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
